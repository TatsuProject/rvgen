# ===== Appended ChipForge master .gitignore =====
# ============================================================
#  ChipForge master .gitignore  —  EDA / RTL / verification
# ============================================================
# Strategy: ignore OUTPUT directories and known artifact extensions.
# Source extensions (.S, .cpp, .v, .sv, .mem, .csv) are NOT blanket-ignored
# at the top level, so source assembly / RTL / test vectors survive.
# They are only excluded when they live inside an ignored output dir.

# ---- Output / generated directories (recursive) ----
build/
build_*/
.build/
out/
out_*/
work/
obj/
obj_dir/
target/
dist/
sim_build/
sim/
runs/
run[0-9]*/
results/
waves/
gen/
csrc/
DVEfiles/
.simvision/
verdiLog/
verdi_logs/
xsim.dir/
.Xil/
*.cache/
*.runs/
*.hw/
*.ip_user_files/
bazel-*/

